# Copy to .env and fill in. .env is gitignored.
PORT=8787
CLAUDE_BIN=claude
# Optional: run claude against a non-default profile/config directory. Equivalent
# to the `CLAUDE_CONFIG_DIR=... claude` shell-alias pattern. Shell aliases don't
# work here (the agent spawns the binary directly, no shell), so set the env var.
# Use an absolute path — dotenv does not expand ~.
# CLAUDE_CONFIG_DIR=/Users/you/.claude-br
# How agent runs reach the local API. Use http://tasklist (port 80 -> pf redirect):
# the pf redirect blackholes direct 127.0.0.1:8787, so localhost would hang.
# setup.sh sets this for you.
TASKLIST_API=http://tasklist
# Slack user token (xoxp-...) with scopes: channels/groups/im/mpim:history,
# channels/groups/im/mpim:read, users:read, search:read
SLACK_USER_TOKEN=
# Discord incoming webhook URL for the daily digest
DISCORD_WEBHOOK_URL=
# Optional per-job model override. Unset = the subscription default (current
# behavior). Downgrading ingest (e.g. to a cheaper model) risks relevance-
# judging quality — measure the cost/quality tradeoff via the usage meter first.
# MODEL_INGEST=
# MODEL_DIGEST=
# MODEL_REPLY=
# MODEL_DIAGNOSE=
# MODEL_EXECUTE=
# Daily notional-$ budget; shows a warning banner when exceeded. 0/unset = off.
# DAILY_BUDGET=
